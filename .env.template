# SSH connection settings (used for SSH tunnel fallback)
SSH_USER=username
SSH_SERVER=your-server.com
SSH_KEY_FILE=~/.ssh/id_ed25519

# SOCKS proxy port (default: 8090)
SOCKS_PORT=8090

# Optional: HTTP proxy port (leave empty to skip pproxy setup)
# Useful for apps that don't support SOCKS (e.g., Docker Desktop free version)
HTTP_PORT=

# Xray VLESS+Reality settings (DPI-resistant tunnel, recommended)
# When set, Xray becomes the primary tunnel; SSH tunnel stays as fallback.
# Generate these on the server with: xray uuid / xray x25519
XRAY_UUID=
XRAY_PUBLIC_KEY=
XRAY_SHORT_ID=
XRAY_SNI=www.google.com
XRAY_SERVER_PORT=443
